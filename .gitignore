# ==================================================
# 📦 Dependencies (패키지 설치 파일)
# ==================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==================================================
# 🧪 Testing (테스트 결과물)
# ==================================================
/coverage

# ==================================================
# ⚡ Next.js Build Outputs (빌드 산출물)
# ==================================================
/.next/
/out/

# ==================================================
# 🚀 Production Build (배포용 결과물)
# ==================================================
/build
/dist

# ==================================================
# 🐞 Logs (디버깅 로그 파일)
# ==================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ==================================================
# 🔐 Environment Variables (환경 변수 - 보안 중요)
# ==================================================
.env*
# 필요 시 특정 파일만 허용 가능
# !.env.production

# ==================================================
# ☁️ Vercel Deployment (배포 캐시)
# ==================================================
.vercel

# ==================================================
# 🧠 TypeScript (빌드 캐시)
# ==================================================
*.tsbuildinfo
next-env.d.ts

# ==================================================
# 🖥️ OS / System (운영체제 파일)
# ==================================================
.DS_Store
Thumbs.db

# ==================================================
# 🔑 Security (보안 키 파일)
# ==================================================
*.pem

# ==================================================
# 🛠️ IDE / Editor (개발 도구 설정)
# ==================================================
.vscode/
.idea/
.shelf/
.workspace.xml

# ==================================================
# 📁 Project-specific (불필요 로컬 파일)
# ==================================================
/queries/
/dataSources/
/dataSources.local.xml
/httpRequests/

# ==================================================
# 📝 Markdown 정책 (문서 관리)
# ==================================================
*.md
!README.md
!CLAUDE.md
!AGENTS.md